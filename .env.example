# Platform Client IDs
VITE_FACEBOOK_CLIENT_ID=your_facebook_client_id
VITE_TWITTER_CLIENT_ID=your_twitter_client_id
VITE_INSTAGRAM_CLIENT_ID=your_instagram_client_id
VITE_TIKTOK_CLIENT_ID=your_tiktok_client_id
VITE_YOUTUBE_CLIENT_ID=your_youtube_client_id

# OAuth Configuration
VITE_OAUTH_REDIRECT_BASE=http://localhost:5173
VITE_OAUTH_CALLBACK_PATH=/auth/callback

# Platform Scopes
VITE_FACEBOOK_SCOPES=pages_manage_posts,pages_read_engagement,publish_video
VITE_TWITTER_SCOPES=tweet.read,tweet.write,users.read,offline.access
VITE_INSTAGRAM_SCOPES=instagram_basic,instagram_content_publish,pages_read_engagement
VITE_TIKTOK_SCOPES=user.info.basic,video.list,video.upload
VITE_YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.upload

# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Platform API Versions
VITE_FACEBOOK_API_VERSION=v18.0
VITE_TWITTER_API_VERSION=2
VITE_INSTAGRAM_API_VERSION=v18.0
VITE_TIKTOK_API_VERSION=v2
VITE_YOUTUBE_API_VERSION=v3

# Netlify Configuration
VITE_NETLIFY_TOKEN=nfp_mLtscnGNHv8XiPJub8RyS1vJY2164HpZ9906

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_RATE_LIMITING=true

# Security
VITE_TOKEN_ENCRYPTION_KEY=your_encryption_key # Generate a secure key for production
